# Dependencies
node_modules/

# Build output
dist/

# TypeScript incremental build cache
*.tsbuildinfo

# Test coverage reports
coverage/

# Environment variables — never commit real secrets
.env
# .env.example should be committed (template with no real values)

# Prisma generated client (regenerated via `prisma generate`)
/generated/prisma/

# Logs
logs/
*.log
npm-debug.log*

# OS / editor artifacts
.DS_Store
Thumbs.db
.idea/
.vscode/

# Terraform state and local cache — contains secrets (DB password, etc.)
# .terraform.lock.hcl is intentionally NOT ignored — it should be committed
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/*.tfvars
!infra/*.tfvars.example
infra/crash.log
infra/override.tf
infra/override.tf.json

# Kubernetes secrets with real values — only the .example template is committed
k8s/secret.yaml

