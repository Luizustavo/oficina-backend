# Database
DATABASE_URL="postgresql://oficina_user:oficina_pass@localhost:5432/oficina_db"
DATABASE_TEST_URL="postgresql://oficina_user:oficina_pass@localhost:5433/oficina_test_db"

# JWT
JWT_SECRET="change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV="development"

# SonarQube (usado apenas com docker-compose.sonar.yml)
# Gere o token em: http://localhost:9000 → My Account → Security → Generate Token
SONAR_TOKEN="your-sonarqube-token-here"
