generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

enum UserRole {
  ADMIN
  MECHANIC
  ATTENDANT
}

enum ServiceOrderStatus {
  RECEIVED
  IN_DIAGNOSIS
  AWAITING_APPROVAL
  IN_PROGRESS
  COMPLETED
  DELIVERED
  CANCELED
}

model Customer {
  id        String       @id @default(uuid())
  name      String
  document  String       @unique
  type      CustomerType
  email     String
  phone     String
  address   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]

  @@map("customers")
}

model Vehicle {
  id           String   @id @default(uuid())
  customerId   String
  licensePlate String   @unique
  brand        String
  model        String
  year         Int
  color        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer      Customer       @relation(fields: [customerId], references: [id])
  serviceOrders ServiceOrder[]

  @@map("vehicles")
}

model Service {
  id                       String   @id @default(uuid())
  name                     String
  description              String?
  price                    Decimal  @db.Decimal(10, 2)
  estimatedDurationMinutes Int
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("services")
}

model Part {
  id               String   @id @default(uuid())
  name             String
  code             String   @unique
  description      String?
  price            Decimal  @db.Decimal(10, 2)
  stockQuantity    Int      @default(0)
  minStockQuantity Int      @default(10)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("parts")
}

model ServiceOrder {
  id                 String             @id @default(uuid())
  orderNumber        String             @unique
  customerId         String
  vehicleId          String
  problemDescription String
  status             ServiceOrderStatus @default(RECEIVED)
  services           Json
  parts              Json
  totalAmount        Decimal            @default(0) @db.Decimal(10, 2)
  notes              String?
  approvedAt         DateTime?
  startedAt          DateTime?
  finishedAt         DateTime?
  deliveredAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id])

  @@map("service_orders")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
