  "info": {
    "title": "Oficina Backend API",
    "description": "Mechanical Workshop Management System - Tech Challenge SOAT Fase 1",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateServiceOrderRequestDto": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "example": "uuid-do-cliente"
          },
          "vehicleId": {
            "type": "string",
            "example": "uuid-do-veiculo"
          },
          "problemDescription": {
            "type": "string",
            "example": "Carro fazendo barulho ao frear e perda de potência"
          },
          "notes": {
            "type": "string",
            "example": "Cliente relatou início dos sintomas há 1 semana"
          }
        },
        "required": [
          "customerId",
          "vehicleId",
          "problemDescription"
        ]
      },
      "BudgetDecisionRequestDto": {
        "type": "object",
        "properties": {
          "decision": {
            "enum": [
              "APPROVED",
              "REJECTED"
            ],
            "type": "string",
            "example": "APPROVED"
          }
        },
        "required": [
          "decision"
        ]
      },
      "AddServiceRequestDto": {
        "type": "object",
        "properties": {
          "serviceId": {
            "type": "string",
            "example": "uuid-do-servico"
          },
          "quantity": {
            "type": "number",
            "minimum": 1,
            "example": 1
          },
          "notes": {
            "type": "string",
            "example": "Incluir troca de filtro de ar junto"
          }
        },
        "required": [
          "serviceId"
        ]
      },
      "AddPartRequestDto": {
        "type": "object",
        "properties": {
          "partId": {
            "type": "string",
            "example": "uuid-da-peca"
          },
          "quantity": {
            "type": "number",
            "minimum": 1,
            "example": 2
          }
        },
        "required": [
          "partId",
          "quantity"
        ]
      },
      "CreateCustomerRequestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "example": "Carlos Pereira"
          },
          "document": {
            "type": "string",
            "example": "123.456.789-09"
          },
          "type": {
            "enum": [
              "INDIVIDUAL",
              "COMPANY"
            ],
            "type": "string",
            "example": "INDIVIDUAL"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "carlos@email.com"
          },
          "phone": {
            "type": "string",
            "example": "(11) 99999-0000"
          },
          "address": {
            "type": "string",
            "example": "Rua das Flores, 123 - São Paulo/SP"
          }
        },
        "required": [
          "name",
          "document",
          "type",
          "email",
          "phone"
        ]
      },
      "UpdateCustomerRequestDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "1254524"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "example": "Carlos A. Pereira"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "carlos.novo@email.com"
          },
          "phone": {
            "type": "string",
            "example": "(11) 98765-4321"
          },
          "address": {
            "type": "string",
            "example": "Av. Paulista, 1000 - São Paulo/SP"
          }
        },
        "required": [
          "id"
        ]
      },
      "CreateVehicleRequestDto": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "example": "uuid-do-cliente"
          },
          "licensePlate": {
            "type": "string",
            "example": "ABC-1234"
          },
          "brand": {
            "type": "string",
            "example": "Toyota"
          },
          "model": {
            "type": "string",
            "example": "Corolla"
          },
          "year": {
            "type": "number",
            "minimum": 1900,
            "maximum": 2100,
            "example": 2022
          },
          "color": {
            "type": "string",
            "example": "Prata"
          }
        },
        "required": [
          "customerId",
          "licensePlate",
          "brand",
          "model",
          "year"
        ]
      },
      "UpdateVehicleRequestDto": {
        "type": "object",
        "properties": {
          "brand": {
            "type": "string",
            "example": "Volkswagen"
          },
          "model": {
            "type": "string",
            "example": "Gol"
          },
          "year": {
            "type": "number",
            "minimum": 1900,
            "maximum": 2100,
            "example": 2023
          },
          "color": {
            "type": "string",
            "example": "Branco"
          }
        }
      },
      "CreateServiceRequestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Troca de óleo"
          },
          "description": {
            "type": "string",
            "example": "Troca de óleo do motor com filtro"
          },
          "price": {
            "type": "number",
            "minimum": 0.01,
            "example": 150
          },
          "estimatedDurationMinutes": {
            "type": "number",
            "minimum": 1,
            "example": 60
          }
        },
        "required": [
          "name",
          "price",
          "estimatedDurationMinutes"
        ]
      },
      "UpdateServiceRequestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Troca de óleo completa"
          },
          "description": {
            "type": "string",
            "example": "Troca de óleo com filtro de ar e vela"
          },
          "price": {
            "type": "number",
            "minimum": 0.01,
            "example": 180
          },
          "estimatedDurationMinutes": {
            "type": "number",
            "minimum": 1,
            "example": 90
          }
        }
      },
      "CreatePartRequestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Filtro de óleo"
          },
          "code": {
            "type": "string",
            "example": "FO-001"
          },
          "description": {
            "type": "string",
            "example": "Filtro de óleo para motores 1.0 e 1.4"
          },
          "price": {
            "type": "number",
            "minimum": 0.01,
            "example": 35.9
          },
          "stockQuantity": {
            "type": "number",
            "minimum": 0,
            "example": 50
          },
          "minStockQuantity": {
            "type": "number",
            "minimum": 0,
            "example": 10
          }
        },
        "required": [
          "name",
          "code",
          "price",
          "stockQuantity",
          "minStockQuantity"
        ]
      },
      "UpdatePartRequestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Filtro de óleo premium"
          },
          "description": {
            "type": "string",
            "example": "Filtro premium para motores 1.0, 1.4 e 1.6"
          },
          "price": {
            "type": "number",
            "minimum": 0.01,
            "example": 45.9
          },
          "minStockQuantity": {
            "type": "number",
            "minimum": 0,
            "example": 15
          }
        }
      },
      "StockOperationDto": {
        "type": "object",
        "properties": {
          "quantity": {
            "type": "number",
            "minimum": 1,
            "example": 20
          }
        },
        "required": [
          "quantity"
        ]
      },
      "LoginRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@oficina.com"
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "example": "Admin123!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshTokenRequestDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "CreateUserRequestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "example": "João da Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "joao@oficina.com"
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "example": "Senha123!"
          },
          "role": {
            "enum": [
              "ADMIN",
              "MECHANIC",
              "ATTENDANT"
            ],
            "type": "string",
            "example": "MECHANIC"
          }
        },
        "required": [
          "name",
          "email",
          "password",
          "role"
        ]
      }
    }
  }
}
